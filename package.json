{
  "name": "stanza-line-counter",
  "displayName": "StanzaLineCounter",
  "description": "Displays the number of lines for each file directly in the Explorer panel.",
  "version": "0.3.1",
  "publisher": "Psychobarge",
  "repository": {
    "type": "git",
    "url": "https://github.com/psychobarge/StanzaLineCounter"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "images/stanza_logo.png",
  "galleryBanner": {
    "color": "#e8eef4",
    "theme": "light"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "StanzaLineCounter",
      "properties": {
        "lineCounter.limit": {
          "type": "number",
          "default": 300,
          "description": "Line count threshold. Files exceeding this limit will have their badge displayed with a warning color."
        },
        "lineCounter.limitColor": {
          "type": "string",
          "default": "editorInfo.foreground",
          "enum": [
            "editorInfo.foreground",
            "errorForeground",
            "charts.red",
            "charts.orange",
            "charts.yellow",
            "charts.green",
            "charts.blue",
            "charts.purple",
            "foreground",
            "descriptionForeground"
          ],
          "enumDescriptions": [
            "Default Blue (Info)",
            "Error Red",
            "Red",
            "Orange",
            "Yellow",
            "Green",
            "Blue",
            "Purple",
            "Default Text Foreground",
            "Subtle Gray (Description)"
          ],
          "description": "The color used for files exceeding the line limit. Select a theme color from the dropdown."
        },
        "lineCounter.excludeExtensions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            ".log",
            ".min.js",
            ".map",
            ".png",
            ".jpg",
            ".jpeg",
            ".gif",
            ".webp",
            ".svg",
            ".ico",
            ".bmp",
            ".tiff",
            ".tif",
            ".avif",
            ".heic",
            ".woff",
            ".woff2",
            ".ttf",
            ".otf",
            ".eot",
            ".pdf",
            ".zip",
            ".gz",
            ".tar",
            ".rar",
            ".7z",
            ".mp3",
            ".mp4",
            ".webm",
            ".wav",
            ".ogg",
            ".bin"
          ],
          "description": "List of file extensions to exclude from line counting (e.g. '.log', '.min.js', '.map', images, fonts, archives, media files)."
        },
        "lineCounter.excludeFolders": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "node_modules",
            ".git",
            "vendor",
            "dist",
            "out",
            "target",
            "bin",
            ".venv",
            "venv",
            "env",
            ".env"
          ],
          "description": "List of folder names to exclude from line counting (e.g. 'node_modules', '.git', 'vendor')."
        },
        "lineCounter.maxFileSizeMB": {
          "type": "number",
          "default": 10,
          "description": "Maximum file size in MB. Files larger than this will be skipped to prevent performance issues."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.74.0",
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  }
}